// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Note: SQLite does not support enums. Enum values are stored as strings.
// TransactionSource: EASY_CRYPTO, LIGHTNING, XAPO, KRAKEN, COINCORNER
// TransactionType: BUY, SELL, TRANSFER, FEE, CASHBACK
// ImportBatchStatus: PENDING, SUCCESS, ERROR

model Transaction {
  id                String          @id @default(uuid())
  source            String          // TransactionSource enum value
  transactionDate   DateTime
  type              String          // TransactionType enum value
  btcAmount         Decimal         // Satoshi precision
  fiatAmount        Decimal
  fiatCurrency      String          @default("NZD")
  feeAmount         Decimal?
  feeCurrency       String?
  price             Decimal         // NZD per BTC
  sourceReference   String?         // Original transaction ID from exchange
  importBatchId     String?
  rawData           String?         // Store original CSV row as JSON string for auditing
  createdAt         DateTime        @default(now())

  importBatch       ImportBatch?    @relation(fields: [importBatchId], references: [id])
  wacCalculation    WACCalculation?

  @@index([transactionDate])
  @@index([source])
  @@index([importBatchId])
}

model WACCalculation {
  id                String      @id @default(uuid())
  transactionId     String      @unique
  calculationDate   DateTime    @default(now())
  runningBalance    Decimal     // BTC balance after this transaction
  runningCost       Decimal     // Total NZD cost basis
  wacPrice          Decimal     // NZD/BTC weighted average cost
  costBasis         Decimal     // Cost basis for this specific transaction
  capitalGain       Decimal?    // Gain/loss for disposal (null for acquisitions)
  createdAt         DateTime    @default(now())

  transaction       Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([calculationDate])
}

model ImportBatch {
  id                String          @id @default(uuid())
  source            String          // TransactionSource enum value
  fileName          String
  recordsImported   Int             @default(0)
  status            String          @default("PENDING") // ImportBatchStatus enum value
  errorMessage      String?
  importedAt        DateTime        @default(now())

  transactions      Transaction[]

  @@index([importedAt])
}

model TaxYear {
  id                  String    @id @default(uuid())
  year                Int       @unique // e.g., 2025 for 2025/2026 tax year
  startDate           DateTime  // e.g., 2025-04-01
  endDate             DateTime  // e.g., 2026-03-31
  openingBtcBalance   Decimal   @default(0)
  openingCostBasis    Decimal   @default(0)
  openingWac          Decimal   @default(0) // Calculated: openingCostBasis / openingBtcBalance
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([year])
}

model CurrencyRate {
  id            String    @id @default(uuid())
  date          DateTime
  fromCurrency  String
  toCurrency    String
  rate          Decimal
  source        String    @default("Manual") // e.g., "XE.com", "RBNZ", "Manual"
  createdAt     DateTime  @default(now())

  @@unique([date, fromCurrency, toCurrency])
  @@index([date])
}
